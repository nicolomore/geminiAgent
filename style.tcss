#chat {
  scrollbar-size: 0 0;
  background: #1e1f29;
  border: round #3b82f6;
  width: 1fr;
}
#inputBar {
  height: 3;
  dock: bottom;
  background: #1e1f29;
  /*border: round #3b82f6;*/
}
#allega {
  width: auto;
  background: #1e1f29;
}
Button.-active {
  border: round #3b82f6;
  background: #3b82f6;
  tint: transparent;
}
Button {
  border: round #3b82f6;
}
#input {
  width: 1fr;
  background: #1e1f29;
  border: round #3b82f6;
}
#input:focus {
  width: 1fr;
  background: #1e1f29;
  border: round #3b82f6;
  background-tint: transparent;
}
#invia {
  width: auto;
  background: #1e1f29;
}
Bubble.user {
  height: auto;
  align-horizontal: right;
}
Bubble.ai {
  height: auto;
  align-horizontal: left;
}
Bubble.user .contenuto {
  height: auto;
  width: auto;
  border: round #3b82f6;
  padding: 0 1;
  max-width: 75%;
}
Bubble.ai .contenuto {
  min-width: 40%;
  border: round #10b981;
  padding: 0 1;
  max-width: 75%;
}
Collapsible{
    width: auto;
    min-width: 40%;
    border: round #00ff00;
    background: #1e1f29;
    background-tint: transparent;
    align-horizontal: left;
}
Collapsible.-expanded{
    width: auto;
    height: auto;
    border: round #00ff00;
    background: #1e1f29;
    background-tint: transparent;
}
